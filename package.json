{
  "name": "mini-harness",
  "version": "1.1.0",
  "description": "Lightweight Agent Skills (ZH + EN): one-command mini harness scaffold for Cursor, Codex & Claude Code.",
  "keywords": [
    "mini-harness",
    "agent-skills",
    "agent-harness",
    "harness",
    "cursor",
    "codex",
    "claude-code",
    "skills-cli",
    "ai-coding"
  ],
  "homepage": "https://github.com/HYX-LHJ/mini-harness#readme",
  "bugs": {
    "url": "https://github.com/HYX-LHJ/mini-harness/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HYX-LHJ/mini-harness.git"
  },
  "license": "MIT",
  "private": false,
  "files": [
    "agent-harness-zh/",
    "agent-harness-en/",
    "docs/",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "skills": {
    "agent-harness-zh": {
      "path": "agent-harness-zh",
      "locale": "zh-CN",
      "install": "npx skills add HYX-LHJ/mini-harness --skill agent-harness-zh -g -y"
    },
    "agent-harness-en": {
      "path": "agent-harness-en",
      "locale": "en",
      "install": "npx skills add HYX-LHJ/mini-harness --skill agent-harness-en -g -y"
    }
  }
}
